{
  "name": "agent-harness-ja",
  "version": "0.1.0",
  "description": "A harness for LLM agents on the Claude Agent SDK: multi-model routing, security guardrails, and adversarial evaluation.",
  "license": "MIT",
  "author": "Jackson Anstee",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "agent-harness-ja": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "node ./dist/cli.js eval",
    "redteam": "node ./dist/cli.js redteam",
    "check:links": "bash scripts/check-links.sh",
    "prepublishOnly": "rm -rf dist && npm run build && npm test && npm run redteam"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.6.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "llm",
    "agent",
    "claude",
    "anthropic",
    "harness",
    "evaluation",
    "prompt-injection",
    "security",
    "telemetry"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacksonanstee/agent-harness-JA.git"
  },
  "bugs": {
    "url": "https://github.com/jacksonanstee/agent-harness-JA/issues"
  },
  "homepage": "https://github.com/jacksonanstee/agent-harness-JA#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "gray-matter": "^4.0.3"
  }
}
